{
  "mcpServers": {
    "cloudwatch": {
      "command": "uvx",
      "args": ["awslabs.cloudwatch-mcp-server@latest"]
    },
    "aws": {
      "command": "uvx",
      "args": ["awslabs.core-mcp-server@latest"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@github/github-mcp-server"]
    },
    "terraform": {
      "command": "npx",
      "args": ["-y", "@hashicorp/terraform-mcp-server"]
    }
  }
}
